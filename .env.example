# QARVIS - variables d'environnement (copier en .env, ne jamais committer .env)

# Cible de test (Cypress Real World App)
BASE_URL=http://localhost:3000
API_URL=http://localhost:3001

# Identifiants de test (via secrets CI en pipeline, jamais en dur)
TEST_USER=
TEST_PASSWORD=

# LLM (ai-brain) - API Anthropic directe, ou creds AWS/Bedrock
ANTHROPIC_API_KEY=

# Observabilité agents (LangSmith)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=qarvis-poc

# RAG (pgvector via Postgres, cf. infra/docker-compose.yml)
DATABASE_URL=postgresql://qarvis:qarvis@localhost:5432/qarvis_rag

# Alerting
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
